{
  "name": "@grapity/hub",
  "version": "0.1.0",
  "type": "module",
  "description": "Grapity Hub - Developer portal for browsing API specs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/grapitydev/hub"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./serve": {
      "import": {
        "types": "./dist/serve.d.ts",
        "default": "./dist/serve.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "preview": "vite preview",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@grapity/core": "^0.1.0",
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.22",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^17.4.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
